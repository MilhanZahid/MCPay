{
  "name": "mcpay",
  "version": "1.0.0",
  "private": true,
  "description": "MCPay — Payment infrastructure layer for MCP tool servers. Arc Testnet + Circle Nanopayments.",
  "workspaces": [
    "scripts",
    "packages/tool-server",
    "packages/mcp-server",
    "packages/frontend"
  ],
  "scripts": {
    "setup": "cd scripts && npm run setup",
    "dev:server": "cd packages/tool-server && npm run dev",
    "dev:frontend": "cd packages/frontend && npm run dev",
    "dev:mcp": "cd packages/mcp-server && npm run dev",
    "build": "npm run build --workspaces --if-present"
  },
  "author": "MCPay Team",
  "license": "MIT"
}
